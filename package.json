    "drizzle-kit": "^0.31.9",
    "drizzle-seed": "^0.3.1",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.1",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
